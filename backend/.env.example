# ---- Core ----
ENVIRONMENT=development            # development | production
APP_NAME=PrepPilot AI

# ---- Database ----
# Deployed: PostgreSQL (asyncpg). Local quick-start can use SQLite (aiosqlite).
DATABASE_URL=postgresql+asyncpg://preppilot:preppilot@localhost:5432/preppilot
# DATABASE_URL=sqlite+aiosqlite:///./preppilot.db

# ---- Auth ----
JWT_SECRET=change-me-in-production-please
JWT_EXPIRE_MINUTES=1440
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# When true (dev only) enables POST /auth/dev-login without Google.
ALLOW_DEV_LOGIN=true

# ---- Encryption at rest (PII: resume text) ----
# 32-byte urlsafe base64 Fernet key. Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ---- LLM (Claude via LiteLLM) ----
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5
LLM_TEMPERATURE=0.2
# When ANTHROPIC_API_KEY is empty, the app runs in MOCK mode (deterministic, free) so it is demoable without a key.

# ---- LangSmith (optional tracing) ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=preppilot
LANGCHAIN_TRACING_V2=false

# ---- Cost & abuse controls ----
DAILY_INTERVIEW_CAP=10
DAILY_LLM_CALL_CAP=120
ANSWER_CHAR_CAP=1800

# ---- Readiness formula ----
READINESS_ALPHA=0.6               # recency decay for EWMA
READINESS_MIN_SESSIONS=5          # small-sample guard

# ---- Privacy ----
RESUME_RETENTION_DAYS=90

# ---- CORS ----
FRONTEND_ORIGIN=http://localhost:3000
